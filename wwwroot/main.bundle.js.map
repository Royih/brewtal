import { Component, OnInit } from '@angular/core';
import { HttpClient } from '@angular/common/http';

@Component({
  selector: 'app-root',
  templateUrl: './app.component.html',
  styleUrls: ['./app.component.css']
})
export class AppComponent implements OnInit {

  title = 'app';
  status = false;

  constructor(private http: HttpClient) {

  }

  ngOnInit(): void {
    this.http.get('http://192.168.1.12:5000/api/pins/get/4/').toPromise().then(res => {
      this.status = res as boolean;
    });
  }

  toggleLed(): void {
    this.status = !this.status;
    this.http.post('http://192.168.1.12:5000/api/pins/set', { PinId: 4, Status: this.status }).toPromise().then(res => {
      console.log('Did toggle', res);
      this.status = res as boolean;
    });
  }

}



